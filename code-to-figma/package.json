{
  "name": "code-to-figma",
  "version": "0.1.0",
  "description": "CLI tool for syncing React components to Figma",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "code-to-figma": "./dist/cli.js",
    "c2f": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "figma",
    "react",
    "design-system",
    "cli",
    "code-to-design"
  ],
  "license": "MIT"
}
